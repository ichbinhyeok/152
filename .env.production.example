IMAGE_NAME=shinhyeok22/152:latest
HOST_PORT=8099
SPRING_PROFILES_ACTIVE=prod
APP_ADMIN_USERNAME=admin
APP_ADMIN_PASSWORD=replace-with-a-strong-password
APP_STORAGE_ROOT=/app/storage
JAVA_OPTS=-XX:+UseG1GC -Xms256m -Xmx512m -Djava.security.egd=file:/dev/./urandom

# Optional overrides
# HOST_PORT=8100
# APP_ADMIN_USERNAME=ops-admin
